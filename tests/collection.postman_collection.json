  "item": [
    {
      "name": "00 - Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test('Status 200 - API online', () => pm.response.to.have.status(200));",
            "pm.test('Retorna info da API', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json).to.have.property('api');",
            "  pm.expect(json).to.have.property('status', 'online');",
            "});"
          ]
        }
      }]
    },
    {
      "name": "01 - Usuários - Criar",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Vanessa Lima\",\n  \"email\": \"vanessa_{{$timestamp}}@unicap.br\",\n  \"senha\": \"senha123\",\n  \"tipo\": \"aluno\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/usuarios", "host": ["{{baseUrl}}"], "path": ["usuarios"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test('Status 201 - Criado', () => pm.response.to.have.status(201));",
            "pm.test('Tem id retornado', () => pm.expect(pm.response.json()).to.have.property('id'));",
            "pm.test('Não retorna senha', () => pm.expect(pm.response.json()).to.not.have.property('senha'));",
            "pm.collectionVariables.set('usuarioId', pm.response.json().id);"
          ]
        }
      }]
    },
